#!/bin/bash
# ralph - オリジナル版 Ralph Loop ランナー
set -e

VERSION="0.4.0"

RALPH_DIR=".ralph"
PROMPT_FILE="${PROMPT_FILE:-.ralph/PROMPT.md}"
TODO_FILE="TODO.md"
TODO_PATTERN="${TODO_PATTERN:-}"
MAX_ITERATIONS="${MAX_ITERATIONS:-50}"
SLEEP_SECONDS="${SLEEP_SECONDS:-60}"

# --todo で指定されたファイル群（複数指定可）
TODO_FILES_CLI=()

show_help() {
  cat <<EOF
ralph $VERSION - Ralph Loop ランナー

使い方:
  ralph init        .ralph/ ディレクトリと PROMPT.md を生成する
  ralph [オプション]  Ralph Loop を実行する

オプション:
  --prompt FILE     指示書ファイル (デフォルト: .ralph/PROMPT.md)
  --todo FILE       進捗ファイルを指定（複数回指定可）
                    省略時は PROMPT.md 内の ralph-config 設定に従って自動検出
  --todo-pattern P  完了判定の grep パターン (デフォルト: "^- \[ \]")
                    feature ファイル使用時: "^- \[ \] F-.*-T[0-9]"
  --max N           最大繰り返し回数・全体合計 (デフォルト: 50)
  --sleep N         周回間の待機秒数 (デフォルト: 60)
  --version         バージョン表示
  --help            このヘルプを表示

PROMPT.md に以下の構造化コメントを書くと、対象ファイルを自動検出します:

  <!-- ralph-config
  TODO_DIRS=docs/features docs/nfr
  TODO_FILES=docs/architecture.md
  EXCLUDE_DIRS=docs/legacy docs/notes
  -->
EOF
}

# ------- init サブコマンド -------

ARCHIVE_DIR="$RALPH_DIR/archive"
SCRATCH_FILE="${SCRATCH_FILE:-$RALPH_DIR/SCRATCH.md}"

write_static_prompt() {
  cat > "$1" <<'PROMPT_EOF'
あなたは自律的に作業するエージェントです。

# 参照ファイル

このループで使うファイルは、いずれもカレントディレクトリ直下にあります。

- **進捗ファイル**: `./TODO.md`
  （実行時オプションで別ファイルが指定されている場合は、メッセージ冒頭の「進捗ファイルの指定」のパスを優先してください）
- **この指示書**: `./.ralph/PROMPT.md`
- **作業ログ**: `./.ralph/SCRATCH.md`
  （存在しなければ新規作成してください）
- **過去サイクルのアーカイブ**: `./.ralph/archive/`
  （前サイクルの `TODO-*.md` と `SCRATCH-*.md` がタイムスタンプ付きで置かれています。必要に応じて読んでください）

# 手順

1. メッセージ冒頭に書かれている「進捗ファイルの指定」のパスを確認してください（指定がなければ `./TODO.md`）
2. その進捗ファイルを読んでください
3. 未完了 ([ ]) のタスクを1つだけ選び、実装してください
   - 保留 ([-]) のタスクはスキップしてください
4. 完了したら進捗ファイルのそのタスクを [x] に変えてください
5. タスクが現時点で完了不可能な場合（環境未構築、外部サービス未設定、前提タスク未完了など）:
   - チェックボックスを `[-]` に変えてください
   - 直後に `<!-- 保留: {理由} -->` をコメントとして追記してください
   - 例: `- [-] F-001-T05: Stripe決済の実装 <!-- 保留: Stripe APIキーが未設定のため実装不可 -->`
6. 何をやったかを `./.ralph/SCRATCH.md` に1〜2行で追記してください
7. 変更をコミットしてください（タスク1つにつき1コミット）
   - コミットメッセージは Conventional Commits 形式: `<型>(<スコープ>): <説明>`
   - 型の例: feat, fix, refactor, test, docs, chore, style, perf
   - スコープ: 機能名や領域（例: auth, cart, api）。省略可。
   - 説明: 命令形で50文字以内（日本語OK: 「〜を追加」「〜を修正」）
   - 例: `feat(auth): ログインAPIのエンドポイントを追加`
   - 例: `test(auth): ログインAPIの統合テストを追加`
   - テストと実装が同じタスクなら1コミットにまとめてよい
   - 保留 ([-]) にしたタスクはコミット不要

# 制約

- 1回の実行で扱うタスクは1つだけ
- 進捗ファイルに書かれていないことはやらない
- 既存のテストを壊さない
- 不明点は `./.ralph/SCRATCH.md` に「QUESTION:」として記録してスキップ
- 同じタスクを保留 ([-]) にするのは1回だけ（既に [-] のタスクは再試行しない）

# feature ファイルを進捗ファイルとして使う場合

進捗ファイルが feature ファイル（管理番号 F-xxx 付き）の場合、以下の追加ルールに従ってください:

- 実装対象は「## タスク」セクションの `- [ ]` 行（F-xxx-T で始まる行）のみ
- 「## 要求」「## 要件」のチェックボックスは追跡用なので触らない
- テストタスクと実装タスクがペアになっている場合は、上から順に処理する（テストが先）
- タスク完了後、そのタスクが参照している技術仕様・要件・要求のチェック伝播は行わない（別途実施）

# このプロジェクト固有のルール

<!-- ralph-config
TODO_DIRS=
TODO_FILES=TODO.md
EXCLUDE_DIRS=
-->

<!-- このセクションに、プロジェクト固有の制約を書いてください。
含めるべき項目:
- 使用言語・ランタイム・パッケージマネージャ
- テストフレームワークと実行コマンド
- Linter / Formatter と実行コマンド
- 触ってはいけないディレクトリ・ファイル
- コミットメッセージ規約
- プロジェクト特有のアーキテクチャ原則

`ralph init` で AI モードを選んだ場合は、ralph-config と合わせて自動で埋まります。 -->
PROMPT_EOF
}

write_static_todo() {
  cat > "$1" <<'TODO_EOF'
# やることリスト

- [ ] (ここに最初のタスクを書く)
- [ ] (ここに次のタスクを書く)
TODO_EOF
}

prompt_yn() {
  local question="$1"
  local default="${2:-Y}"
  # 非対話環境では常に false（AI 起動や .gitignore 変更など副作用のある操作をスキップ）
  if [ ! -t 0 ]; then
    return 1
  fi
  local answer
  printf "%s" "$question"
  read -r answer
  answer="${answer:-$default}"
  [[ "$answer" =~ ^[Yy]$ ]]
}

archive_current_cycle() {
  # TODO.md と SCRATCH.md を .ralph/archive/ に移動（タイムスタンプ付き）
  local ts
  ts=$(date +%Y%m%d-%H%M%S)
  mkdir -p "$ARCHIVE_DIR"
  if [ -f "$TODO_FILE" ]; then
    mv "$TODO_FILE" "$ARCHIVE_DIR/TODO-$ts.md"
    echo "  $TODO_FILE → $ARCHIVE_DIR/TODO-$ts.md"
  fi
  if [ -f "$SCRATCH_FILE" ]; then
    mv "$SCRATCH_FILE" "$ARCHIVE_DIR/SCRATCH-$ts.md"
    echo "  $SCRATCH_FILE → $ARCHIVE_DIR/SCRATCH-$ts.md"
  fi
}

snapshot_for_inheritance() {
  # TODO.md を .ralph/archive/ にコピー（スナップショット、元は残す）
  local ts
  ts=$(date +%Y%m%d-%H%M%S)
  mkdir -p "$ARCHIVE_DIR"
  if [ -f "$TODO_FILE" ]; then
    cp "$TODO_FILE" "$ARCHIVE_DIR/TODO-$ts-inherited.md"
    echo "  $TODO_FILE を $ARCHIVE_DIR/TODO-$ts-inherited.md に記録しました（引き継ぎ元）"
  fi
  if [ -f "$SCRATCH_FILE" ]; then
    cp "$SCRATCH_FILE" "$ARCHIVE_DIR/SCRATCH-$ts-inherited.md"
  fi
}

launch_claude() {
  local initial_prompt="$1"
  if ! command -v claude >/dev/null; then
    echo "エラー: claude コマンドが見つかりません。" >&2
    echo "     AI モードには Claude Code のインストールが必要です。" >&2
    exit 1
  fi
  echo ""
  echo "Claude Code を対話モードで起動します..."
  echo "（対話が終わったら /exit で終了し、生成物を確認してから 'ralph' を実行してください）"
  echo ""
  claude "$initial_prompt"
}

run_ai_new() {
  local p="ralph-init スキルを『新規モード』で使ってください。カレントディレクトリには骨格のみの $PROMPT_FILE が置かれています。プロジェクトを調査し、タスクファイルの方針（TODO.md を新規作成するか、既存の feature ファイル等を使うか）をユーザーと相談してください。$PROMPT_FILE の \"# このプロジェクト固有のルール\" セクション（ralph-config 含む）を更新し、必要であれば TODO.md も作成してください。"
  launch_claude "$p"
}

run_ai_cycle() {
  local p="ralph-init スキルを『サイクル継続モード』で使ってください。$PROMPT_FILE は既に存在し変更不要です。前サイクルの TODO.md と SCRATCH.md は $ARCHIVE_DIR/ にタイムスタンプ付きでアーカイブされています。最新のアーカイブを読み、何が完了したか理解したうえで、次サイクル用の TODO.md をユーザと対話で作成してください。$PROMPT_FILE は触らないでください。"
  launch_claude "$p"
}

run_ai_inherit() {
  local p="ralph-init スキルを『引き継ぎモード』で使ってください。前サイクルの未完了タスクが残った TODO.md が現在のディレクトリにあり、同じ内容が $ARCHIVE_DIR/TODO-*-inherited.md にスナップショットとして保存されています。TODO.md から未完了 ([ ]) タスクを抽出し、整理・追加提案をユーザと対話して新しい TODO.md を作成してください。$PROMPT_FILE は触らないでください。"
  launch_claude "$p"
}

prompt_gitignore_update() {
  local gi=".gitignore"
  [ -f "$gi" ] || return 0

  local need_scratch=false
  local need_archive=false
  local need_logs=false
  grep -qxF "$RALPH_DIR/SCRATCH.md" "$gi" || need_scratch=true
  grep -qxF "$RALPH_DIR/archive/" "$gi" || need_archive=true
  grep -qxF "$RALPH_DIR/logs/" "$gi" || need_logs=true

  if [ "$need_scratch" = false ] && [ "$need_archive" = false ] && [ "$need_logs" = false ]; then
    return 0
  fi

  local entries=""
  [ "$need_scratch" = true ] && entries="$entries $RALPH_DIR/SCRATCH.md"
  [ "$need_archive" = true ] && entries="$entries $RALPH_DIR/archive/"
  [ "$need_logs" = true ] && entries="$entries $RALPH_DIR/logs/"

  echo ""
  if prompt_yn ".gitignore に$entries を追加しますか？(Y/n): " "Y"; then
    [ "$need_scratch" = true ] && echo "$RALPH_DIR/SCRATCH.md" >> "$gi"
    [ "$need_archive" = true ] && echo "$RALPH_DIR/archive/" >> "$gi"
    [ "$need_logs" = true ] && echo "$RALPH_DIR/logs/" >> "$gi"
    echo "✓ .gitignore を更新しました"
  else
    echo "(.gitignore 更新はスキップしました)"
  fi
}

# --- 各パターンの処理 ---

cmd_init_first_time() {
  echo "新規プロジェクトとして初期化します。"
  echo ""

  local use_ai=false
  if prompt_yn "AI で生成しますか？(Y/n): " "Y"; then
    use_ai=true
  fi

  mkdir -p "$RALPH_DIR"
  write_static_prompt "$PROMPT_FILE"
  echo "✓ $PROMPT_FILE を作成しました"

  if [ "$use_ai" = true ]; then
    # AI モードでは TODO.md を事前に作らない
    # スキルがプロジェクトを調査し、TODO.md を作るか feature ファイルを使うかをユーザーと相談して決める
    run_ai_new
  else
    # 非 AI モードでは雛形の TODO.md を作成
    write_static_todo "$TODO_FILE"
    echo "✓ $TODO_FILE を作成しました"
  fi
}

cmd_init_next_cycle() {
  echo "前サイクルが完了しています。次のサイクルへ移行します。"
  echo ""
  echo "アーカイブ中..."
  archive_current_cycle

  write_static_todo "$TODO_FILE"
  echo "✓ 新しい $TODO_FILE を作成しました"

  if prompt_yn "AI で次サイクルの TODO.md を作成しますか？(Y/n): " "Y"; then
    run_ai_cycle
  fi
}

cmd_init_incomplete() {
  local incomplete
  incomplete=$(grep -cE "^- \[ \]" "$TODO_FILE" 2>/dev/null | tr -d '\n')
  echo "未完了タスクが $incomplete 件残っています。"
  echo "  (1) 新しい TODO.md に引き継ぐ"
  echo "  (2) そのままアーカイブして新規作成"
  echo "  (3) 中止"

  local choice
  if [ -t 0 ]; then
    printf "選択 [1/2/3]: "
    read -r choice
  else
    choice="3"
    echo "(非対話環境のため中止します)"
  fi

  case "$choice" in
    1)
      snapshot_for_inheritance
      if prompt_yn "AI で引き継ぎ整理しますか？(Y/n): " "Y"; then
        run_ai_inherit
      else
        echo ""
        echo "$TODO_FILE を手動で編集してから 'ralph' を実行してください。"
      fi
      ;;
    2)
      echo "アーカイブ中..."
      archive_current_cycle
      write_static_todo "$TODO_FILE"
      echo "✓ 新しい $TODO_FILE を作成しました"
      if prompt_yn "AI で次サイクルの TODO.md を作成しますか？(Y/n): " "Y"; then
        run_ai_cycle
      fi
      ;;
    *)
      echo "中止しました。"
      exit 0
      ;;
  esac
}

cmd_init() {
  echo "===== ralph init ====="

  local has_prompt=false
  local has_todo=false
  local incomplete=0

  [ -f "$PROMPT_FILE" ] && has_prompt=true
  [ -f "$TODO_FILE" ] && has_todo=true

  if [ "$has_todo" = true ]; then
    incomplete=$(grep -cE "^- \[ \]" "$TODO_FILE" 2>/dev/null | tr -d '\n')
    incomplete=${incomplete:-0}
  fi

  if [ "$has_prompt" = false ]; then
    cmd_init_first_time
  elif [ "$incomplete" -gt 0 ]; then
    cmd_init_incomplete
  else
    cmd_init_next_cycle
  fi

  prompt_gitignore_update

  echo ""
  echo "===== init 完了 ====="
  echo "生成物を確認してから 'ralph' を実行してください。"
}

# ------- ralph-config 解析 & ファイル検出 -------

# PROMPT.md 内の <!-- ralph-config ... --> を解析する
CONFIG_TODO_DIRS=""
CONFIG_TODO_FILES=""
CONFIG_EXCLUDE_DIRS=""

parse_ralph_config() {
  local prompt_file="$1"
  local in_config=false

  while IFS= read -r line; do
    if [[ "$line" == *"<!-- ralph-config"* ]]; then
      in_config=true
      continue
    fi
    if [ "$in_config" = true ] && [[ "$line" == *"-->"* ]]; then
      in_config=false
      continue
    fi
    if [ "$in_config" = true ]; then
      case "$line" in
        TODO_DIRS=*)    CONFIG_TODO_DIRS="${line#TODO_DIRS=}" ;;
        TODO_FILES=*)   CONFIG_TODO_FILES="${line#TODO_FILES=}" ;;
        EXCLUDE_DIRS=*) CONFIG_EXCLUDE_DIRS="${line#EXCLUDE_DIRS=}" ;;
      esac
    fi
  done < "$prompt_file"
}

is_file_done() {
  # frontmatter の status: done を検出
  local file="$1"
  head -20 "$file" | sed -n '/^---$/,/^---$/p' | grep -qE "^status:\s*done"
}

has_incomplete_tasks() {
  # ファイルに未完了タスクがあるか（feature 形式 or 通常形式）
  local file="$1"
  if is_file_done "$file"; then
    return 1
  fi
  grep -qE "^- \[ \]" "$file"
}

is_excluded() {
  # ファイルが除外ディレクトリに含まれるか
  local file="$1"
  local excludes="$2"
  for ex in $excludes; do
    # 末尾スラッシュを正規化
    ex="${ex%/}/"
    if [[ "$file" == "$ex"* || "$file" == "./$ex"* ]]; then
      return 0
    fi
  done
  return 1
}

discover_todo_files() {
  # ralph-config の設定に基づいて対象ファイルを検出
  local dirs="$1"
  local files="$2"
  local excludes="$3"
  local result=()

  # ディレクトリからスキャン
  for dir in $dirs; do
    dir="${dir%/}"
    if [ ! -d "$dir" ]; then
      echo "⚠ 警告: ディレクトリが見つかりません: $dir" >&2
      continue
    fi
    while IFS= read -r f; do
      if is_excluded "$f" "$excludes"; then
        continue
      fi
      if has_incomplete_tasks "$f"; then
        result+=("$f")
      fi
    done < <(find "$dir" -name "*.md" -print | sort)
  done

  # 個別ファイル
  for f in $files; do
    if [ ! -f "$f" ]; then
      continue
    fi
    if is_excluded "$f" "$excludes"; then
      continue
    fi
    if has_incomplete_tasks "$f"; then
      # 重複チェック
      local dup=false
      for r in "${result[@]}"; do
        if [ "$r" = "$f" ]; then
          dup=true
          break
        fi
      done
      if [ "$dup" = false ]; then
        result+=("$f")
      fi
    fi
  done

  printf '%s\n' "${result[@]}"
}

# ------- サブコマンドディスパッチ -------

if [[ "${1:-}" == "init" ]]; then
  shift
  cmd_init "$@"
  exit 0
fi

# ------- Ralph Loop 本体 -------

while [[ $# -gt 0 ]]; do
  case $1 in
    --prompt)       PROMPT_FILE="$2"; shift 2 ;;
    --todo)         TODO_FILES_CLI+=("$2"); shift 2 ;;
    --todo-pattern) TODO_PATTERN="$2"; shift 2 ;;
    --max)          MAX_ITERATIONS="$2"; shift 2 ;;
    --sleep)        SLEEP_SECONDS="$2"; shift 2 ;;
    --version)      echo "ralph $VERSION"; exit 0 ;;
    --help|-h)      show_help; exit 0 ;;
    *) echo "不明なオプション: $1" >&2; show_help; exit 1 ;;
  esac
done

[ -f "$PROMPT_FILE" ] || { echo "エラー: $PROMPT_FILE が見つかりません。先に 'ralph init' を実行してください" >&2; exit 1; }
command -v claude >/dev/null || { echo "エラー: claude コマンドが見つかりません" >&2; exit 1; }

# ------- 対象ファイルの決定 -------

TARGET_FILES=()

if [ ${#TODO_FILES_CLI[@]} -gt 0 ]; then
  # --todo で明示指定 → 指定されたファイルのみ
  for f in "${TODO_FILES_CLI[@]}"; do
    [ -f "$f" ] || { echo "エラー: $f が見つかりません" >&2; exit 1; }
    TARGET_FILES+=("$f")
  done
else
  # PROMPT.md 内の ralph-config を解析して自動検出
  parse_ralph_config "$PROMPT_FILE"

  if [ -n "$CONFIG_TODO_DIRS" ] || [ -n "$CONFIG_TODO_FILES" ]; then
    mapfile -t TARGET_FILES < <(discover_todo_files "$CONFIG_TODO_DIRS" "$CONFIG_TODO_FILES" "$CONFIG_EXCLUDE_DIRS")
  fi

  if [ ${#TARGET_FILES[@]} -eq 0 ]; then
    echo "エラー: 対象ファイルが見つかりません" >&2
    echo "  以下のいずれかを行ってください:" >&2
    echo "  - .ralph/PROMPT.md の <!-- ralph-config --> に TODO_DIRS / TODO_FILES を設定" >&2
    echo "  - --todo オプションでファイルを指定" >&2
    echo "  - 'ralph init' で初期設定を行う" >&2
    exit 1
  fi
fi

if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "⚠ 警告: gitリポジトリではありません。事故時に巻き戻せません。続けますか? (y/N)"
  read -r answer < /dev/tty
  [[ "$answer" != "y" ]] && exit 0
fi

mkdir -p "$RALPH_DIR/logs"
LOG_FILE="$RALPH_DIR/logs/ralph-$(date +%Y%m%d-%H%M%S).log"

trap 'echo ""; echo "===== Ralph 中断されました ====="; exit 130' INT TERM

# ------- タスク集計ヘルパー -------

# タスク行のパターンを返す（feature ファイル or 通常 TODO）
get_task_pattern() {
  local todo_file="$1"
  local custom_pattern="$2"
  if [ -n "$custom_pattern" ]; then
    echo "$custom_pattern"
  elif grep -qE "^- \[[ x-]\] F-.*-T[0-9]" "$todo_file"; then
    echo "^- \[.\] F-.*-T[0-9]"
  else
    echo "^- \[.\]"
  fi
}

# タスク数を集計して表示する
show_task_summary() {
  local todo_file="$1"
  local custom_pattern="$2"
  local pattern
  pattern=$(get_task_pattern "$todo_file" "$custom_pattern")

  local total done todo hold
  total=$(grep -cE "$pattern" "$todo_file" 2>/dev/null || echo 0)
  done=$(grep -cE "^- \[x\]" "$todo_file" 2>/dev/null || echo 0)
  hold=$(grep -cE "^- \[-\]" "$todo_file" 2>/dev/null || echo 0)
  todo=$(grep -cE "^- \[ \]" "$todo_file" 2>/dev/null || echo 0)

  # feature ファイルの場合、タスク行だけをカウント
  if grep -qE "^- \[[ x-]\] F-.*-T[0-9]" "$todo_file"; then
    total=$(grep -cE "^- \[[ x-]\] F-.*-T[0-9]" "$todo_file" 2>/dev/null || echo 0)
    done=$(grep -cE "^- \[x\] F-.*-T[0-9]" "$todo_file" 2>/dev/null || echo 0)
    hold=$(grep -cE "^- \[-\] F-.*-T[0-9]" "$todo_file" 2>/dev/null || echo 0)
    todo=$(grep -cE "^- \[ \] F-.*-T[0-9]" "$todo_file" 2>/dev/null || echo 0)
  fi

  echo "  タスク: $todo 残 / $total 全体 ($done 完了, $hold 保留)"
}

# 全ファイル横断のタスク集計を表示する
# 引数: TARGET_FILES 配列（グローバル変数）を参照
show_global_summary() {
  local g_total=0 g_done=0 g_todo=0 g_hold=0

  for f in "${TARGET_FILES[@]}"; do
    local total done todo hold
    if grep -qE "^- \[[ x-]\] F-.*-T[0-9]" "$f" 2>/dev/null; then
      total=$(grep -cE "^- \[[ x-]\] F-.*-T[0-9]" "$f" 2>/dev/null || echo 0)
      done=$(grep -cE "^- \[x\] F-.*-T[0-9]" "$f" 2>/dev/null || echo 0)
      hold=$(grep -cE "^- \[-\] F-.*-T[0-9]" "$f" 2>/dev/null || echo 0)
      todo=$(grep -cE "^- \[ \] F-.*-T[0-9]" "$f" 2>/dev/null || echo 0)
    else
      total=$(grep -cE "^- \[.\]" "$f" 2>/dev/null || echo 0)
      done=$(grep -cE "^- \[x\]" "$f" 2>/dev/null || echo 0)
      hold=$(grep -cE "^- \[-\]" "$f" 2>/dev/null || echo 0)
      todo=$(grep -cE "^- \[ \]" "$f" 2>/dev/null || echo 0)
    fi
    g_total=$((g_total + total))
    g_done=$((g_done + done))
    g_todo=$((g_todo + todo))
    g_hold=$((g_hold + hold))
  done

  echo "  全体: $g_todo 残 / $g_total 全タスク ($g_done 完了, $g_hold 保留) [${#TARGET_FILES[@]} ファイル]"
}

# 次に取り組むタスクを表示する
show_next_task() {
  local todo_file="$1"
  local next_task

  if grep -qE "^- \[[ x-]\] F-.*-T[0-9]" "$todo_file"; then
    next_task=$(grep -m1 -E "^- \[ \] F-.*-T[0-9]" "$todo_file" 2>/dev/null)
  else
    next_task=$(grep -m1 -E "^- \[ \]" "$todo_file" 2>/dev/null)
  fi

  if [ -n "$next_task" ]; then
    echo "  次: $next_task"
  fi
}

# ------- 1ファイル処理関数 -------

# run_single_file: 1つの TODO ファイルを処理する
# 戻り値: 0=全タスク完了, 1=未完了タスクあり, 2=グローバル上限到達
run_single_file() {
  local todo_file="$1"
  local file_label="$2"

  echo "" | tee -a "$LOG_FILE"
  echo "===== $file_label =====" | tee -a "$LOG_FILE"
  echo "TODO:    $todo_file" | tee -a "$LOG_FILE"
  if [ -n "$TODO_PATTERN" ]; then
    echo "PATTERN: $TODO_PATTERN (手動指定)" | tee -a "$LOG_FILE"
  elif grep -qE "^- \[[ x-]\] F-.*-T[0-9]" "$todo_file"; then
    echo "PATTERN: feature ファイル検出 — タスク行のみで完了判定" | tee -a "$LOG_FILE"
  fi
  show_global_summary | tee -a "$LOG_FILE"
  show_task_summary "$todo_file" "$TODO_PATTERN" | tee -a "$LOG_FILE"
  show_next_task "$todo_file" | tee -a "$LOG_FILE"
  echo "" | tee -a "$LOG_FILE"

  while true; do
    # グローバル上限チェック
    if [ $TOTAL_ITERATIONS -ge $MAX_ITERATIONS ]; then
      echo "全体の最大回数に到達 ($MAX_ITERATIONS 回)" | tee -a "$LOG_FILE"
      return 2
    fi

    TOTAL_ITERATIONS=$((TOTAL_ITERATIONS + 1))
    echo "" | tee -a "$LOG_FILE"
    echo "===== Iteration $TOTAL_ITERATIONS / $MAX_ITERATIONS ($file_label) =====" | tee -a "$LOG_FILE"
    show_global_summary | tee -a "$LOG_FILE"
    show_task_summary "$todo_file" "$TODO_PATTERN" | tee -a "$LOG_FILE"
    show_next_task "$todo_file" | tee -a "$LOG_FILE"

    {
      echo "# 進捗ファイルの指定"
      echo "- 進捗ファイル: $todo_file"
      echo ""
      cat "$PROMPT_FILE"
    } | claude --dangerously-skip-permissions 2>&1 | tee -a "$LOG_FILE"

    local completion_pattern
    if [ -n "$TODO_PATTERN" ]; then
      completion_pattern="$TODO_PATTERN"
    elif grep -qE "^- \[[ x-]\] F-.*-T[0-9]" "$todo_file"; then
      completion_pattern="^- \[ \] F-.*-T[0-9]"
    else
      completion_pattern="^- \[ \]"
    fi
    if ! grep -qE "$completion_pattern" "$todo_file"; then
      echo "全タスク完了: $todo_file" | tee -a "$LOG_FILE"
      return 0
    fi

    echo "${SLEEP_SECONDS}秒待機... (Ctrl+Cで中断可能)" | tee -a "$LOG_FILE"
    sleep "$SLEEP_SECONDS"
  done
}

# ------- メインループ -------

TOTAL_ITERATIONS=0

echo "===== Ralph $VERSION 起動 =====" | tee "$LOG_FILE"
echo "PROMPT:  $PROMPT_FILE" | tee -a "$LOG_FILE"
echo "MAX:     $MAX_ITERATIONS 回（全体合計）" | tee -a "$LOG_FILE"
echo "SLEEP:   $SLEEP_SECONDS 秒"  | tee -a "$LOG_FILE"
if [ ${#TODO_FILES_CLI[@]} -gt 0 ]; then
  echo "MODE:    --todo で明示指定" | tee -a "$LOG_FILE"
else
  echo "MODE:    ralph-config による自動検出" | tee -a "$LOG_FILE"
fi
echo "FILES:   ${#TARGET_FILES[@]} 件の対象ファイル" | tee -a "$LOG_FILE"
for f in "${TARGET_FILES[@]}"; do
  echo "  - $f" | tee -a "$LOG_FILE"
done
echo "" | tee -a "$LOG_FILE"
show_global_summary | tee -a "$LOG_FILE"

COMPLETED_COUNT=0
GLOBAL_MAX_REACHED=false

for todo_file in "${TARGET_FILES[@]}"; do
  file_label=$(basename "$todo_file")
  run_single_file "$todo_file" "$file_label"
  ret=$?

  if [ $ret -eq 0 ]; then
    COMPLETED_COUNT=$((COMPLETED_COUNT + 1))
  elif [ $ret -eq 2 ]; then
    GLOBAL_MAX_REACHED=true
    break
  else
    # ファイル内の全タスク未完了のまま（ここには通常来ないが安全のため）
    break
  fi
done

# 保留タスクの集計
hold_total=0
for todo_file in "${TARGET_FILES[@]}"; do
  hold_count=$(grep -cE "^- \[-\]" "$todo_file" 2>/dev/null || echo 0)
  hold_total=$((hold_total + hold_count))
done

echo "" | tee -a "$LOG_FILE"
echo "===== Ralph 終了 =====" | tee -a "$LOG_FILE"
echo "  完了ファイル: $COMPLETED_COUNT / ${#TARGET_FILES[@]}" | tee -a "$LOG_FILE"
echo "  合計: $TOTAL_ITERATIONS 回の iteration" | tee -a "$LOG_FILE"
if [ "$GLOBAL_MAX_REACHED" = true ]; then
  echo "  ※ 全体の最大回数 ($MAX_ITERATIONS) に到達して停止" | tee -a "$LOG_FILE"
fi
if [ "$hold_total" -gt 0 ]; then
  echo "  保留: $hold_total 件のタスク ([-] マーカー)" | tee -a "$LOG_FILE"
fi
